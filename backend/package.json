{
  "name": "ai-tools-backend",
  "version": "0.1.0",
  "main": "src/server.js",
  "dependencies": {
    "axios": "^1.5.0",
    "bcrypt": "6.0.0",
    "bullmq": "^5.77.6",
    "cheerio": "^1.0.0-rc.12",
    "connect-mongo": "5.0.0",
    "cors": "2.8.5",
    "csv-parse": "^5.3.6",
    "dotenv": "16.0.3",
    "express": "4.22.2",
    "express-session": "1.19.0",
    "mongoose": "7.8.9",
    "node-cron": "4.2.1",
    "passport": "0.6.0",
    "passport-google-oauth20": "2.0.0",
    "passport-local": "1.0.0",
    "playwright": "^1.60.0",
    "rss-parser": "^3.12.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "jest": "29.6.1",
    "mongodb-memory-server": "11.1.0",
    "nodemon": "3.1.14",
    "prettier": "2.8.8",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "<rootDir>/tests/jest.setup.js",
    "testTimeout": 20000
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/scripts/seed.js",
    "importer": "node src/scripts/autoImport.js",
    "portal:bootstrap": "node src/scripts/runStudentAutomation.js",
    "portal:schedule": "node src/scripts/runStudentAutomation.js --watch",
    "internships:run": "node src/scripts/runInternshipAutomation.js",
    "internships:schedule": "node src/scripts/runInternshipAutomation.js --watch",
    "news:run": "node src/scripts/runAINewsAutomation.js",
    "news:schedule": "node src/scripts/runAINewsAutomation.js --watch",
    "scrape:run": "node src/scripts/runScrapingAutomation.js",
    "scrape:schedule": "node src/scripts/runScrapingAutomation.js --watch",
    "scrape:parallel": "node src/scripts/runScrapingAutomation.js --parallel",
    "scrape:toolify": "node src/scripts/runScrapingAutomation.js --scraper toolify",
    "scrape:futurepedia": "node src/scripts/runScrapingAutomation.js --scraper futurepedia",
    "scrape:github": "node src/scripts/runScrapingAutomation.js --scraper github",
    "scrape:producthunt": "node src/scripts/runScrapingAutomation.js --scraper producthunt",
    "test": "cross-env NODE_ENV=test jest --runInBand || jest --runInBand",
    "format": "prettier --write ."
  }
}
